{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "strict": false,
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "skipLibCheck": true,
    "types": []
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx"
  ]
}
