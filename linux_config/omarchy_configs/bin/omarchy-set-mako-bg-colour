#!/bin/bash

# Path to your mako config
TARGET="$HOME/.config/mako/config"

if [ -f "$TARGET" ]; then
    # 1. Match 'background-color=#' followed by exactly 6 hex digits.
    # 2. Capture those 6 digits into group \1.
    # 3. Ignore any trailing 2 digits if they already exist.
    # 4. Rewrite the line with the original 6 digits + 99 (for ~60% opacity).
    sed -i --follow-symlinks -E 's/^(background-color=#[0-9a-fA-F]{6})([0-9a-fA-F]{2})?$/\199/' "$TARGET"
    
    # Reload mako to apply the "frost" immediately
    makoctl reload
else
    echo "Error: Config file not found at $TARGET"
fi